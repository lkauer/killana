---
import { Image } from 'astro:assets';
import type { Translation } from '@/i18n/types';

interface Props {
  t: Translation;
}

const { t } = Astro.props;
const editorialSrc = '/images/sapatos que celebram a autenticidade.jpg';
---

<section class="section-padding relative" id="institucional" data-cms="authenticity">
  <div
    class="absolute inset-0 bg-cover bg-center"
    style={`background-image: linear-gradient(135deg, rgba(31,31,31,0.92), rgba(139,106,78,0.85)), url('${editorialSrc}')`}
    aria-hidden="true"
  ></div>

  <div class="relative z-10 container-killana max-w-3xl mx-auto text-center text-offwhite fade-in">
    <span class="eyebrow">{t.authenticity.eyebrow}</span>
    <h2 class="section-title mb-8">{t.authenticity.title}</h2>
    <div class="space-y-5 text-offwhite/90 text-base md:text-[1.0625rem] leading-relaxed">
      {t.authenticity.paragraphs.map((p) => (
        <p>{p}</p>
      ))}
      <p class="font-serif text-xl md:text-2xl italic text-leather leading-snug pt-4">
        {t.authenticity.highlight}
      </p>
    </div>
  </div>
</section>

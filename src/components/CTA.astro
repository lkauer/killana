---
import type { Translation } from '@/i18n/types';
import { WHATSAPP_URL } from '@/data/site';

interface Props {
  t: Translation;
}

const { t } = Astro.props;
const ctaBg = '/images/tarja entre em contato.jpg';
---

<section class="relative overflow-hidden" id="contato" data-cms="cta">
  <div
    class="absolute inset-0 bg-cover bg-center"
    style={`background-image: linear-gradient(135deg, rgba(31,31,31,0.92), rgba(139,106,78,0.85)), url('${ctaBg}')`}
    aria-hidden="true"
  ></div>

  <div class="relative z-10 container-killana text-center py-24 md:py-32 lg:py-40 text-offwhite fade-in">
    <span class="eyebrow eyebrow-light">{t.cta.eyebrow}</span>
    <h2 class="font-serif text-3xl md:text-5xl lg:text-6xl font-normal mb-6">{t.cta.title}</h2>
    <p class="text-base md:text-lg text-offwhite/85 max-w-lg mx-auto mb-10">{t.cta.text}</p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="btn-primary btn-large">
        {t.cta.button}
      </a>
    </div>

    <div class="mt-16 max-w-4xl mx-auto text-left text-offwhite/90">
      <h3 class="font-serif text-2xl md:text-3xl font-normal mb-6">EQUIPE DE VENDAS MULTIMARCAS - KILLANA</h3>

      <div class="overflow-hidden rounded-3xl border border-offwhite/10 bg-white/5">
        <div class="grid grid-cols-[180px_180px_1fr] gap-4 px-6 py-4 text-xs uppercase tracking-[0.2em] text-offwhite/70 border-b border-offwhite/10">
          <span>{t.cta.representative}</span>
          <span>{t.cta.phone}</span>
          <span>{t.cta.region}</span>
        </div>
        <div class="divide-y divide-offwhite/10 text-sm md:text-base">
          <div class="grid grid-cols-[180px_180px_1fr] gap-4 px-6 py-4 items-start">
            <span class="font-semibold uppercase">ERNI</span>
            <span class="font-mono">51 99993-1630</span>
            <span>RIO GRANDE DO SUL<br />SANTA CATARINA</span>
          </div>
          <div class="grid grid-cols-[180px_180px_1fr] gap-4 px-6 py-4 items-start">
            <span class="font-semibold uppercase">MAIKEL</span>
            <span class="font-mono">41 99665-4114</span>
            <span>PARANÁ</span>
          </div>
          <div class="grid grid-cols-[180px_180px_1fr] gap-4 px-6 py-4 items-start">
            <span class="font-semibold uppercase">NÉIA</span>
            <span class="font-mono">11 99901-5673</span>
            <span>SÃO PAULO<br />CAPITAL/GRANDE SÃO PAULO<br />LITORAL/VALE DO PARAÍBA</span>
          </div>
          <div class="grid grid-cols-[180px_180px_1fr] gap-4 px-6 py-4 items-start">
            <span class="font-semibold uppercase">MURILO</span>
            <span class="font-mono">81 99651-6881</span>
            <span>INTERIOR SÃO PAULO<br />BRAGANÇA PAULISTA/CAMPINAS<br />INTERIOR SÃO PAULO</span>
          </div>
          <div class="grid grid-cols-[180px_180px_1fr] gap-4 px-6 py-4 items-start">
            <span class="font-semibold uppercase">FERNANDO</span>
            <span class="font-mono">61 99995-1031</span>
            <span>GOIÁS/DISTRITO FEDERAL</span>
          </div>
          <div class="grid grid-cols-[180px_180px_1fr] gap-4 px-6 py-4 items-start">
            <span class="font-semibold uppercase">TAYSE</span>
            <span class="font-mono">71 98711-6071</span>
            <span>BAHIA/SERGIPE</span>
          </div>
          <div class="grid grid-cols-[180px_180px_1fr] gap-4 px-6 py-4 items-start">
            <span class="font-semibold uppercase">{t.cta.internalTeam}</span>
            <span class="font-mono">51 99566-8823</span>
            <span>RJ/ES/MG/MT/MS<br />AL/PE/PB/RN + NORTE</span>
          </div>
          <div class="grid grid-cols-[180px_180px_1fr] gap-4 px-6 py-4 items-start">
            <span class="font-semibold uppercase">IGOR</span>
            <span class="font-mono">27 99229-9460</span>
            <span>ESPÍRITO SANTO</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

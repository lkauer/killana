---
import type { Translation } from '@/i18n/types';
import { EXPORT_WHATSAPP_URL, WHATSAPP_URL } from '@/data/site';

interface Props {
  t: Translation;
}

const { t } = Astro.props;
const ctaBg = '/images/tarja entre em contato.jpg';
const contacts = [
  { name: 'ERNI', phone: '51 99993-1630', region: 'RIO GRANDE DO SUL, SANTA CATARINA' },
  { name: 'MAIKEL', phone: '41 99665-4114', region: 'PARANÁ' },
  { name: 'NÉIA', phone: '11 99901-5673', region: 'SÃO PAULO, CAPITAL/GRANDE SÃO PAULO, LITORAL/VALE DO PARAÍBA' },
  { name: 'MURILO', phone: '81 99651-6881', region: 'INTERIOR SÃO PAULO, BRAGANÇA PAULISTA/CAMPINAS, INTERIOR SÃO PAULO' },
  { name: 'FERNANDO', phone: '61 99995-1031', region: 'GOIÁS/DISTRITO FEDERAL' },
  { name: 'TAYSE', phone: '71 98711-6071', region: 'BAHIA/SERGIPE' },
  { name: t.cta.internalTeam, phone: '51 99566-8823', region: 'RJ/ES/MG/MT/MS, AL/PE/PB/RN + NORTE' },
  { name: 'IGOR', phone: '27 99229-9460', region: 'ESPÍRITO SANTO' },
];
---

<section class="relative overflow-hidden" id="contato" data-cms="cta">
  <div
    class="absolute inset-0 bg-cover bg-center"
    style={`background-image: linear-gradient(135deg, rgba(31,31,31,0.92), rgba(139,106,78,0.85)), url('${ctaBg}')`}
    aria-hidden="true"
  ></div>

  <div class="relative z-10 container-killana text-center py-24 md:py-32 lg:py-40 text-offwhite fade-in">
    <span class="eyebrow eyebrow-light">{t.cta.eyebrow}</span>
    <h2 class="font-serif text-3xl md:text-5xl lg:text-6xl font-normal mb-6">{t.cta.title}</h2>
    <p class="text-base md:text-lg text-offwhite/85 max-w-lg mx-auto mb-10">{t.cta.text}</p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="btn-primary btn-large">
        {t.cta.contact}
      </a>
      <a href={EXPORT_WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="btn-primary btn-large">
        {t.cta.exportSales}
      </a>
    </div>

    <div class="mt-16 max-w-4xl mx-auto text-left text-offwhite/90">
      <h3 class="font-serif text-2xl md:text-3xl font-normal mb-6">EQUIPE DE VENDAS MULTIMARCAS - KILLANA</h3>

      <div class="overflow-hidden rounded-3xl border border-offwhite/10 bg-white/5">
        <div class="hidden sm:grid sm:grid-cols-[180px_180px_1fr] gap-4 px-6 py-4 text-xs uppercase tracking-[0.2em] text-offwhite/70 border-b border-offwhite/10">
          <span>{t.cta.representative}</span>
          <span>{t.cta.phone}</span>
          <span>{t.cta.region}</span>
        </div>
        <div class="divide-y divide-offwhite/10 text-sm md:text-base">
          {contacts.map((contact) => (
            <div class="grid gap-3 px-4 py-4 sm:grid-cols-[180px_180px_1fr] sm:gap-4 sm:items-start sm:px-6">
              <div class="flex items-center justify-between gap-3 sm:block">
                <span class="text-[0.65rem] uppercase tracking-[0.2em] text-offwhite/60 sm:hidden">{t.cta.representative}</span>
                <span class="font-semibold uppercase">{contact.name}</span>
              </div>
              <div class="flex items-center justify-between gap-3 sm:block">
                <span class="text-[0.65rem] uppercase tracking-[0.2em] text-offwhite/60 sm:hidden">{t.cta.phone}</span>
                <span class="font-mono">{contact.phone}</span>
              </div>
              <div class="flex items-start justify-between gap-3 sm:block">
                <span class="text-[0.65rem] uppercase tracking-[0.2em] text-offwhite/60 sm:hidden">{t.cta.region}</span>
                <span class="whitespace-normal break-words">{contact.region}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

---
interface Props {
  type: 'social' | 'environment' | 'national' | 'design';
  class?: string;
}

const { type, class: className = 'w-12 h-12' } = Astro.props;
---

{type === 'social' && (
  <svg class={className} viewBox="0 0 48 48" fill="none" aria-hidden="true">
    <circle cx="24" cy="16" r="6" stroke="currentColor" stroke-width="1.5"/>
    <path d="M8 40c0-8.837 7.163-16 16-16s16 7.163 16 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
)}
{type === 'environment' && (
  <svg class={className} viewBox="0 0 48 48" fill="none" aria-hidden="true">
    <path d="M24 4L6 14v14c0 10 8 16 18 20 10-4 18-10 18-20V14L24 4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
    <path d="M24 16v16M16 24h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
)}
{type === 'national' && (
  <svg class={className} viewBox="0 0 48 48" fill="none" aria-hidden="true">
    <path d="M24 44s16-10 16-24a16 16 0 10-32 0c0 14 16 24 16 24z" stroke="currentColor" stroke-width="1.5"/>
    <circle cx="24" cy="20" r="4" stroke="currentColor" stroke-width="1.5"/>
  </svg>
)}
{type === 'design' && (
  <svg class={className} viewBox="0 0 48 48" fill="none" aria-hidden="true">
    <path d="M8 40l8-28h16l8 28H8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
    <path d="M18 20h12M20 28h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
)}

---
import type { Translation } from '@/i18n/types';
import { EXPORT_WHATSAPP_URL, WHATSAPP_URL } from '@/data/site';

interface Props {
  t: Translation;
}

const { t } = Astro.props;
---

<section class="section-padding" id="sobre" data-cms="about">
  <div class="container-killana">
    <header class="mb-12 md:mb-16 fade-in">
      <span class="eyebrow">{t.about.eyebrow}</span>
      <h2 class="section-title">{t.about.title}</h2>
    </header>

    <div class="max-w-3xl space-y-5 mb-16 md:mb-24 fade-in">
      {t.about.paragraphs.map((p) => (
        <p class="text-base md:text-[1.0625rem] leading-[1.85] text-softblack/85">{p}</p>
      ))}
    </div>

    <div class="relative max-w-2xl mx-auto pl-10 fade-in" data-delay="100">
      <div class="absolute left-[7px] top-0 bottom-0 w-px bg-gradient-to-b from-gold to-beige" aria-hidden="true"></div>

      {t.about.timeline.map((item) => (
        <article class="relative pb-12 last:pb-0 group">
          <div class="absolute -left-10 top-1 w-[15px] h-[15px] rounded-full bg-offwhite border-2 border-gold transition-all duration-400 group-hover:bg-gold group-hover:scale-125" aria-hidden="true"></div>
          <span class="block text-xs font-medium tracking-[0.15em] uppercase text-gold mb-2">{item.year}</span>
          <h3 class="font-serif text-xl md:text-2xl font-medium mb-2">{item.title}</h3>
          <p class="text-sm md:text-[0.9375rem] text-softblack/75 leading-relaxed">{item.description}</p>
          {item.badges && (
            <div class="flex gap-3 mt-4">
              {item.badges.map((badge) => (
                <span class="inline-block px-5 py-2 text-xs font-semibold tracking-widest uppercase bg-leather text-offwhite">
                  {badge}
                </span>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>

    <div class="text-center mt-16 fade-in">
      <div class="flex flex-wrap justify-center gap-4">
        <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="btn-primary btn-outline-dark">
          {t.cta.contact}
        </a>
        <a href={EXPORT_WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="btn-primary btn-outline-dark">
          {t.cta.exportSales}
        </a>
      </div>
    </div>
  </div>
</section>
